# Discord Bot Token (Required)
# Get from: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_token_here

# BrightData API Token (Optional)
# Required only for Reddit clip fetching fallback
# Get from: https://brightdata.com
# Note: This is optional and only used when Reddit's direct API blocks requests
BRIGHTDATA_API_TOKEN=your_brightdata_token_here
